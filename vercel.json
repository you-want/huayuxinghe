{
  "version": 2,
  "functions": {
    "server.js": {
      "runtime": "@vercel/node",
      "includeFiles": [
        "index.html",
        "css/**",
        "js/**",
        "lib/**"
      ]
    },
    "api/analyze.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
